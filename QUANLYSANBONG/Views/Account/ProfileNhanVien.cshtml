@model QUANLYSANBONG.Models.NhanVien
@{
    ViewData["Title"] = "Hồ sơ nhân viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container section-padding pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h2 class="section-title">Hồ sơ nhân viên</h2>
            
            <div class="card-custom p-4 mb-4 border-start border-primary border-5">
                <div class="d-flex align-items-center mb-4">
                    <img src="https://ui-avatars.com/api/?name=@Model.HoTen&background=1e3a8a&color=fff&size=128" alt="@Model.HoTen" class="rounded-circle me-4 shadow-sm" width="100">
                    <div>
                        <h3 class="fw-bold mb-1">@Model.HoTen</h3>
                        <p class="text-muted mb-0"><span class="badge bg-primary">@Model.ChucVu</span></p>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="text-muted small text-uppercase fw-bold">Họ và tên</label>
                        <p class="fs-5 fw-medium">@Model.HoTen</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small text-uppercase fw-bold">Số điện thoại</label>
                        <p class="fs-5 fw-medium">@Model.SoDienThoai</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small text-uppercase fw-bold">Email công việc</label>
                        <p class="fs-5 fw-medium">@Model.Email</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small text-uppercase fw-bold">Quyền hạn</label>
                        <p class="fs-5 fw-medium">Truy cập hệ thống quản trị</p>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary px-4"><i class="fa-solid fa-gauge me-2"></i> Vào trang quản trị</a>
                </div>
            </div>
        </div>
    </div>
</div>
