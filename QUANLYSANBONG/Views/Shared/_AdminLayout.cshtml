<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SanBong.vn</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <a asp-controller="Home" asp-action="Index" class="logo-section text-decoration-none">
            <div class="logo-icon">
                <i class="fas fa-trophy"></i>
            </div>
            <div class="logo-text">
                <h5>SanBong.vn</h5>
                <span>Quản lý sân thể thao</span>
            </div>
        </a>

        <nav class="nav flex-column">
            <p class="menu-label">TỔNG QUAN</p>
            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Admin" asp-action="Dashboard">
                <i class="fas fa-th-large"></i> Dashboard
            </a>

            <p class="menu-label">QUẢN LÝ SÂN</p>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SanBong" ? "active" : "")" asp-controller="SanBong" asp-action="Index">
                <i class="fas fa-list"></i> Danh sách sân
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminLoaiSan" ? "active" : "")" asp-controller="AdminLoaiSan" asp-action="Index">
                <i class="fas fa-layer-group"></i> Loại sân
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DatLich" ? "active" : "")" asp-controller="DatLich" asp-action="Index">
                <i class="fas fa-calendar-alt"></i> Đặt lịch
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "BangGiaKhungGio" ? "active" : "")" asp-controller="BangGiaKhungGio" asp-action="Index">
                <i class="fas fa-tag"></i> Bảng giá
            </a>

            <p class="menu-label">QUẢN LÝ BÁN HÀNG</p>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DatSan" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" asp-controller="DatSan" asp-action="Index">
                <i class="fas fa-clipboard-list"></i> Danh sách đơn đặt
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "KhachHang" ? "active" : "")" asp-controller="KhachHang" asp-action="Index">
                <i class="fas fa-users"></i> Khách hàng
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DichVu" ? "active" : "")" asp-controller="DichVu" asp-action="Index">
                <i class="fas fa-concierge-bell"></i> Dịch vụ
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "HoaDon" ? "active" : "")" asp-controller="HoaDon" asp-action="Index">
                <i class="fas fa-file-invoice-dollar"></i> Thanh toán hóa đơn
            </a>

            <p class="menu-label">QUẢN LÝ NỘI DUNG</p>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminBlog" ? "active" : "")" asp-controller="AdminBlog" asp-action="Index">
                <i class="fas fa-newspaper"></i> Bài viết Blog
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminBlogCategory" ? "active" : "")" asp-controller="AdminBlogCategory" asp-action="Index">
                <i class="fas fa-folder-open"></i> Chuyên mục Blog
            </a>

            <p class="menu-label">BÁO CÁO</p>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "BaoCao" ? "active" : "")" asp-controller="BaoCao" asp-action="Index">
                <i class="fas fa-chart-line"></i> Doanh thu
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "NhatKyThaoTac" ? "active" : "")" asp-controller="NhatKyThaoTac" asp-action="Index">
                <i class="fas fa-history"></i> Nhật ký thao tác
            </a>

            <p class="menu-label">HỆ THỐNG</p>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "NhanVien" ? "active" : "")" asp-controller="NhanVien" asp-action="Index">
                <i class="fas fa-user-tie"></i> Nhân viên
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "NguoiDung" ? "active" : "")" asp-controller="NguoiDung" asp-action="Index">
                <i class="fas fa-user-shield"></i> Tài khoản
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "CaiDat" ? "active" : "")" asp-controller="CaiDat" asp-action="Index">
                <i class="fas fa-cog"></i> Cài đặt
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Topbar -->
        <header class="topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn border-0 p-0"><i class="fas fa-bars fs-5"></i></button>
                <div class="d-none d-md-block">
                    <span class="fw-medium" id="current-date">Thứ Năm, 04/06/2026</span>
                    <span class="mx-2 text-muted">|</span>
                    <span class="text-primary fw-bold" id="current-time">08:00:00</span>
                    <span class="ms-3 text-warning"><i class="fas fa-sun me-1"></i> 32°C</span>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-light rounded-circle" id="theme-toggle" title="Đổi giao diện">
                    <i class="fas fa-moon"></i>
                </button>
                
                <div class="dropdown">
                    <button class="btn btn-light rounded-circle position-relative" data-bs-toggle="dropdown" aria-expanded="false" id="notification-btn">
                        <i class="fas fa-bell"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger p-1 d-none" id="notification-badge" style="font-size: 0.5rem;">0</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 p-0 overflow-hidden" id="notification-list" style="width: 320px; border-radius: 12px;">
                        <li class="p-3 border-bottom bg-light">
                            <h6 class="mb-0 fw-bold">Thông báo</h6>
                        </li>
                        <li id="notification-items">
                            <!-- Dữ liệu sẽ được load qua AJAX -->
                            <div class="p-4 text-center text-muted small">Đang tải thông báo...</div>
                        </li>
                        <li>
                            <a class="dropdown-item p-2 text-center small text-primary fw-bold" asp-controller="DatSan" asp-action="Index">Xem tất cả đơn đặt</a>
                        </li>
                    </ul>
                </div>

                <div class="dropdown border-start ps-3">
                    <a href="#" class="d-flex align-items-center gap-2 text-decoration-none" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center position-relative fw-bold" style="width: 38px; height: 38px;">
                            @(Context.Session.GetString("TenDangNhap")?.Substring(0, 1).ToUpper() ?? "A")
                            <span class="position-absolute bottom-0 end-0 badge rounded-circle bg-success border border-white p-1"></span>
                        </div>
                        <div class="d-none d-lg-block">
                            <div class="fw-bold text-dark small" style="line-height: 1.2;">@Context.Session.GetString("TenDangNhap")</div>
                            <div class="text-muted" style="font-size: 0.7rem;">@Context.Session.GetString("VaiTro")</div>
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" style="border-radius: 12px; min-width: 200px;">
                        <li><a class="dropdown-item py-2 px-3" asp-controller="Account" asp-action="Profile"><i class="fas fa-user-circle me-2 text-primary"></i> Hồ sơ của tôi</a></li>
                        <li><a class="dropdown-item py-2 px-3" asp-controller="CaiDat" asp-action="Index"><i class="fas fa-cog me-2 text-secondary"></i> Cài đặt hệ thống</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 px-3 text-danger" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a></li>
                    </ul>
                </div>
            </div>
        </header>

        <div class="p-4">
            @RenderBody()
        </div>
    </main>

    <a href="#" class="floating-chat">
        <i class="fas fa-comment-dots"></i>
        <span>Tin nhắn</span>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Cập nhật thời gian thực tế
        function updateClock() {
            const now = new Date();
            const days = ['Chủ Nhật', 'Thứ Hai', 'Thứ Ba', 'Thứ Tư', 'Thứ Năm', 'Thứ Sáu', 'Thứ Bảy'];
            const timeStr = now.toLocaleTimeString('vi-VN');
            const dateStr = days[now.getDay()] + ', ' + now.toLocaleDateString('vi-VN', { year: 'numeric', month: '2-digit', day: '2-digit' });
            
            const timeEl = document.getElementById('current-time');
            const dateEl = document.getElementById('current-date');
            
            if(timeEl) timeEl.textContent = timeStr;
            if(dateEl) dateEl.textContent = dateStr;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Xử lý Dark Mode
        const themeToggle = document.getElementById('theme-toggle');
        const body = document.body;
        const html = document.documentElement;

        // Kiểm tra cài đặt trước đó
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
            html.setAttribute('data-bs-theme', 'dark');
            themeToggle.innerHTML = '<i class="fas fa-sun"></i>';
        }

        themeToggle.addEventListener('click', () => {
            const isDark = html.getAttribute('data-bs-theme') === 'dark';
            if (isDark) {
                html.removeAttribute('data-bs-theme');
                themeToggle.innerHTML = '<i class="fas fa-moon"></i>';
                localStorage.setItem('theme', 'light');
            } else {
                html.setAttribute('data-bs-theme', 'dark');
                themeToggle.innerHTML = '<i class="fas fa-sun"></i>';
                localStorage.setItem('theme', 'dark');
            }
        });

        // Tải thông báo thực tế
        async function loadNotifications() {
            try {
                const response = await fetch('@Url.Action("GetLatestNotifications", "Admin")');
                if (!response.ok) return;
                const data = await response.json();
                
                const container = document.getElementById('notification-items');
                const badge = document.getElementById('notification-badge');
                
                if (data && data.length > 0) {
                    badge.textContent = data.length;
                    badge.classList.remove('d-none');
                    
                    container.innerHTML = data.map(item => `
                        <a class="dropdown-item p-3 border-bottom d-flex gap-3" href="${item.type === 'Booking' ? '/DatSan/Index' : '/HoaDon/Index'}">
                            <div class="${item.class} bg-opacity-10 text-${item.class.split('-')[1]} rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; flex-shrink: 0;">
                                <i class="fas ${item.icon}"></i>
                            </div>
                            <div style="white-space: normal;">
                                <div class="small fw-bold">${item.title}</div>
                                <div class="small text-muted">${item.content}</div>
                                <div class="text-primary mt-1" style="font-size: 0.7rem;">${formatTime(item.time)}</div>
                            </div>
                        </a>
                    `).join('');
                } else {
                    badge.classList.add('d-none');
                    container.innerHTML = '<div class="p-4 text-center text-muted small">Không có thông báo mới</div>';
                }
            } catch (error) {
                console.error('Lỗi tải thông báo:', error);
            }
        }

        function formatTime(timeStr) {
            const date = new Date(timeStr);
            const now = new Date();
            const diffMs = now - date;
            const diffMins = Math.floor(diffMs / 60000);
            const diffHours = Math.floor(diffMins / 60)
            
            if (diffMins < 1) return 'Vừa xong';
            if (diffMins < 60) return `${diffMins} phút trước`;
            if (diffHours < 24) return `${diffHours} giờ trước`;
            return date.toLocaleDateString('vi-VN');
        }

        // Tải thông báo khi mở trang và mỗi 5 phút
        loadNotifications();
        setInterval(loadNotifications, 300000);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
