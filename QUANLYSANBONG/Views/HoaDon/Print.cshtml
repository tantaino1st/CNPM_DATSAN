@model QUANLYSANBONG.Models.HoaDon
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hóa Đơn #@Model.MaHD - Quản Lý Sân Bóng</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #fff; padding: 20px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .invoice-box { max-width: 800px; margin: auto; padding: 30px; border: 1px solid #eee; box-shadow: 0 0 10px rgba(0, 0, 0, .15); }
        .invoice-header { text-align: center; margin-bottom: 30px; }
        .invoice-header h2 { margin: 0; color: #198754; font-weight: bold; }
        .invoice-info { margin-bottom: 20px; }
        .table-invoice th { background-color: #f8f9fa; }
        .total-row th, .total-row td { font-size: 1.2rem; font-weight: bold; }
        @@media print {
            .no-print { display: none !important; }
            .invoice-box { box-shadow: none; border: none; padding: 0; }
        }
    </style>
</head>
<body>
    <div class="invoice-box">
        <div class="text-end mb-3 no-print">
            <button onclick="window.print()" class="btn btn-primary"><i class="fa-solid fa-print"></i> In Hóa Đơn</button>
            <a href="javascript:history.back()" class="btn btn-secondary">Quay lại</a>
        </div>

        <div class="invoice-header">
            <h2>HỆ THỐNG QUẢN LÝ SÂN BÓNG</h2>
            <p class="mb-0">Địa chỉ: 123 Đường ABC, Quận XYZ, TP.HCM</p>
            <p>Điện thoại: 0909 123 456</p>
            <hr />
            <h4 class="mt-3">HÓA ĐƠN THANH TOÁN</h4>
            <p>Mã hóa đơn: <strong>#@Model.MaHD</strong> | Ngày lập: @(Model.NgayThanhToan?.ToString("dd/MM/yyyy HH:mm") ?? "-")</p>
        </div>

        <div class="row invoice-info">
            <div class="col-sm-6">
                <strong>Khách hàng:</strong> @(Model.DatSan?.KhachHang?.HoTen ?? "Khách lẻ")<br />
                <strong>Số điện thoại:</strong> @(Model.DatSan?.KhachHang?.SoDienThoai ?? "N/A")
            </div>
            <div class="col-sm-6 text-end">
                <strong>Sân:</strong> @Model.DatSan?.SanBong?.TenSan<br />
                <strong>Ngày đặt:</strong> @Model.DatSan?.NgayDat.ToString("dd/MM/yyyy")<br />
                <strong>Khung giờ:</strong> @(Model.DatSan?.BangGiaKhungGio != null ? $"{Model.DatSan.BangGiaKhungGio.GioBatDau:hh\\:mm} - {Model.DatSan.BangGiaKhungGio.GioKetThuc:hh\\:mm}" : "N/A")
            </div>
        </div>

        <table class="table table-bordered table-invoice mt-4">
            <thead>
                <tr>
                    <th width="5%">STT</th>
                    <th>Nội dung</th>
                    <th class="text-end">Đơn giá</th>
                    <th class="text-center">Số lượng</th>
                    <th class="text-end">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                <!-- Tiền sân -->
                <tr>
                    <td class="text-center">1</td>
                    <td>Tiền thuê sân (@(Model.DatSan?.SanBong?.TenSan))</td>
                    <td class="text-end">-</td>
                    <td class="text-center">1</td>
                    <td class="text-end">@string.Format("{0:N0}", Model.TienSan)</td>
                </tr>
                
                <!-- Dịch vụ -->
                @{ int stt = 2; }
                @if (ViewBag.ChiTietDichVus != null)
                {
                    foreach (var ct in ViewBag.ChiTietDichVus as IEnumerable<QUANLYSANBONG.Models.ChiTietDichVu>)
                    {
                        <tr>
                            <td class="text-center">@stt</td>
                            <td>@ct.DichVu?.TenDichVu</td>
                            <td class="text-end">@string.Format("{0:N0}", ct.DonGia)</td>
                            <td class="text-center">@ct.SoLuong</td>
                            <td class="text-end">@string.Format("{0:N0}", ct.ThanhTien)</td>
                        </tr>
                        stt++;
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="4" class="text-end fw-bold">Tổng cộng:</td>
                    <td class="text-end fw-bold">@string.Format("{0:N0}", Model.TienSan + Model.TienDichVu)</td>
                </tr>
                @if (Model.PhuThu > 0)
                {
                    <tr>
                        <td colspan="4" class="text-end">Phụ thu khác:</td>
                        <td class="text-end">@string.Format("{0:N0}", Model.PhuThu)</td>
                    </tr>
                }
                @if (Model.GiamGia > 0)
                {
                    <tr>
                        <td colspan="4" class="text-end">Giảm giá:</td>
                        <td class="text-end">-@string.Format("{0:N0}", Model.GiamGia)</td>
                    </tr>
                }
                @if (Model.DatSan?.TienCoc > 0)
                {
                    <tr>
                        <td colspan="4" class="text-end">Đã đặt cọc:</td>
                        <td class="text-end">-@string.Format("{0:N0}", Model.DatSan.TienCoc)</td>
                    </tr>
                }
                <tr class="total-row text-danger">
                    <td colspan="4" class="text-end">KHÁCH CẦN THANH TOÁN:</td>
                    <td class="text-end">@string.Format("{0:N0}", Model.TongTien) VNĐ</td>
                </tr>
            </tfoot>
        </table>

        <div class="row mt-5">
            <div class="col-6 text-center">
                <strong>Khách hàng</strong><br />
                <small>(Ký, ghi rõ họ tên)</small>
            </div>
            <div class="col-6 text-center">
                <strong>Nhân viên lập phiếu</strong><br />
                <small>(Ký, ghi rõ họ tên)</small>
            </div>
        </div>
        
        <div class="text-center mt-5 pt-5 text-muted small">
            <p>Xin cảm ơn quý khách và hẹn gặp lại!</p>
        </div>
    </div>
</body>
</html>