            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <a href="@Url.Action("Index", "LoaiSan", new { loai = "Bóng chuyền" })" class="category-card">
                    <div class="icon-wrapper"><i class="fa-solid fa-volleyball"></i></div>
                    <h5>Bóng chuyền</h5>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <a asp-controller="LoaiSan" asp-action="Pickleball" class="category-card">
                    <div class="icon-wrapper"><i class="fa-solid fa-medal"></i></div>
                    <h5>Pickleball</h5>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <a href="@Url.Action("Index", "LoaiSan", new { loai = "Bơi lội" })" class="category-card">
                    <div class="icon-wrapper"><i class="fa-solid fa-swimmer"></i></div>
                    <h5>Bơi lội</h5>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <a asp-controller="LoaiSan" asp-action="Index" class="category-card">
                    <div class="icon-wrapper"><i class="fa-solid fa-ellipsis"></i></div>
                    <h5>Môn khác</h5>
                </a>
            </div>
        </div>
    </div>
</section>

