@model QUANLYSANBONG.Models.HoaDon
@{
    ViewData["Title"] = "Lập Hóa Đơn";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Lập Hóa Đơn Mới</h6>
    </div>
    <div class="card-body">
        <div class="alert alert-info">
            <i class="fa-solid fa-circle-info"></i> <strong>Thông tin đặt sân:</strong> @ViewData["DatSanInfo"]
        </div>
        
        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="MaDatSan" />
            <input type="hidden" asp-for="NgayThanhToan" />
            
            <partial name="_Form" model="Model" />
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
