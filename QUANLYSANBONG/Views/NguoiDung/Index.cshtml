@model IEnumerable<QUANLYSANBONG.Models.NguoiDung>
@{
    ViewData["Title"] = "Quản lý Tài Khoản";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách Tài Khoản</h6>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="fa-solid fa-plus"></i> Thêm tài khoản
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th width="50">ID</th>
                        <th>Tên đăng nhập</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th width="120" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MaNguoiDung</td>
                                <td><strong>@item.TenDangNhap</strong></td>
                                <td><span class="badge bg-secondary">@item.VaiTro?.TenVaiTro</span></td>
                                <td>
                                    @if (item.TrangThai)
                                    {
                                        <span class="text-success"><i class="fa-solid fa-circle-check"></i> Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger"><i class="fa-solid fa-lock"></i> Đã khóa</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.MaNguoiDung" class="btn btn-sm btn-warning" title="Sửa">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">Không có dữ liệu</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
