@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Quản Lý Sân Bóng</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f0f2f5;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            overflow: hidden;
            width: 100%;
            max-width: 450px;
        }
        .login-header {
            background-color: #198754;
            color: white;
            padding: 20px;
            text-align: center;
        }
        .login-body {
            padding: 30px;
            background-color: white;
        }
        .form-control:focus {
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25);
            border-color: #198754;
        }
        .btn-login {
            background-color: #198754;
            color: white;
            font-weight: bold;
            padding: 10px;
            border-radius: 8px;
            transition: all 0.3s;
        }
        .btn-login:hover {
            background-color: #157347;
            color: white;
            transform: translateY(-2px);
        }
    </style>
</head>
<body>

<div class="container d-flex justify-content-center">
    <div class="login-card">
        <div class="login-header">
            <i class="fa-solid fa-futbol fa-3x mb-2"></i>
            <h4 class="mb-0">Hệ Thống Quản Lý Sân Bóng</h4>
        </div>
        <div class="login-body">
            <h5 class="text-center mb-4 text-muted">Vui lòng đăng nhập</h5>
            
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger p-2 text-center" role="alert">
                    <i class="fa-solid fa-circle-exclamation"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                <div class="mb-3">
                    <label for="PhoneOrEmail" class="form-label text-muted">Tên đăng nhập (SĐT hoặc Email)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fa-solid fa-user"></i></span>
                        <input type="text" class="form-control" id="PhoneOrEmail" name="PhoneOrEmail" required placeholder="Nhập SĐT hoặc Email" />
                    </div>
                </div>
                <div class="mb-4">
                    <label for="matKhau" class="form-label text-muted">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fa-solid fa-lock"></i></span>
                        <input type="password" class="form-control" id="matKhau" name="matKhau" required placeholder="Nhập mật khẩu (VD: 123456)" />
                    </div>
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-login">
                        ĐĂNG NHẬP <i class="fa-solid fa-arrow-right-to-bracket ms-1"></i>
                    </button>
                </div>
                <div class="mt-4 text-center">
                    <span>Chưa có tài khoản? </span>
                    <a asp-action="Register" class="text-success text-decoration-none fw-bold">Đăng ký ngay</a>
                </div>
                <div class="mt-3 text-center">
                    <small class="text-muted">Tài khoản mặc định: admin / 123456</small>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>