@model QUANLYSANBONG.Models.LoaiSan
@{
    ViewData["Title"] = "Xóa loại sân";
    Layout = "_AdminLayout";
}

<div class="mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none small"><i class="fas fa-arrow-left me-1"></i> Quay lại danh sách</a>
    <h3 class="fw-bold mt-2 text-danger">Xác nhận xóa loại sân</h3>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 text-center p-5">
            <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4" style="width: 80px; height: 80px; font-size: 2.5rem;">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h4 class="fw-bold">Bạn có chắc chắn?</h4>
            <p class="text-muted mb-4">Hành động xóa loại sân <strong>@Model.TenLoaiSan</strong> không thể hoàn tác. Vui lòng kiểm tra kỹ trước khi thực hiện.</p>
            
            <form asp-action="Delete">
                <input type="hidden" asp-for="MaLoaiSan" />
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger py-2 rounded-3 fw-bold shadow-sm">XÓA VĨNH VIỄN</button>
                    <a asp-action="Index" class="btn btn-light py-2 rounded-3 border">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>
