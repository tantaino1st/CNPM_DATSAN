@model IEnumerable<QUANLYSANBONG.Models.DichVu>
@{
    ViewData["Title"] = "Quản lý Dịch Vụ";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách Dịch Vụ</h6>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="fa-solid fa-plus"></i> Thêm dịch vụ
        </a>
    </div>
    <div class="card-body">
        
        <!-- Search Form -->
        <form asp-action="Index" method="get" class="mb-4">
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Tên dịch vụ..." />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-search"></i> Tìm kiếm</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th width="50">ID</th>
                        <th>Tên dịch vụ</th>
                        <th>Đơn vị tính</th>
                        <th>Đơn giá (VNĐ)</th>
                        <th>Tồn kho</th>
                        <th width="150" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MaDichVu</td>
                                <td><strong>@item.TenDichVu</strong></td>
                                <td>@item.DonViTinh</td>
                                <td class="text-end text-primary fw-bold">@string.Format("{0:N0}", item.DonGia)</td>
                                <td class="text-end">
                                    @if (item.TonKho <= 10)
                                    {
                                        <span class="text-danger fw-bold">@item.TonKho</span>
                                    }
                                    else
                                    {
                                        @item.TonKho
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.MaDichVu" class="btn btn-sm btn-warning" title="Sửa">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.MaDichVu" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa dịch vụ này?');">
                                        <button type="submit" class="btn btn-sm btn-danger" title="Xóa">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">Không tìm thấy dịch vụ nào phù hợp</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
