@model IEnumerable<QUANLYSANBONG.Models.DatSan>
@{
    ViewData["Title"] = "Danh sách đơn đặt sân";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Quản lý Đơn đặt sân</h3>
    <a asp-action="Create" class="btn btn-primary px-4 shadow-sm">
        <i class="fas fa-plus me-2"></i>Thêm đơn mới
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label small fw-bold">Từ ngày</label>
                <input type="date" name="fromDate" class="form-control" value="@ViewData["FromDate"]" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold">Đến ngày</label>
                <input type="date" name="toDate" class="form-control" value="@ViewData["ToDate"]" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold">Trạng thái</label>
                <select name="trangThai" class="form-select">
                    <option value="">-- Tất cả --</option>
                    <option value="Cho xac nhan" selected="@(ViewData["CurrentTrangThai"]?.ToString() == "Cho xac nhan")">Chờ xác nhận</option>
                    <option value="Da xac nhan" selected="@(ViewData["CurrentTrangThai"]?.ToString() == "Da xac nhan")">Đã xác nhận</option>
                    <option value="Da hoan thanh" selected="@(ViewData["CurrentTrangThai"]?.ToString() == "Da hoan thanh")">Đã hoàn thành</option>
                    <option value="Da huy" selected="@(ViewData["CurrentTrangThai"]?.ToString() == "Da huy")">Đã hủy</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-success px-4 w-100">Lọc dữ liệu</button>
                <a asp-action="Index" class="btn btn-light border"><i class="fas fa-undo"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Khách hàng</th>
                    <th>Sân bóng</th>
                    <th>Thời gian chơi</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-dark">@item.KhachHang?.HoTen</div>
                            <div class="text-muted small">@item.KhachHang?.SoDienThoai</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.SanBong?.TenSan</div>
                            <div class="badge bg-light text-dark border">@item.SanBong?.LoaiSan?.TenLoaiSan</div>
                        </td>
                        <td>
                            <div class="fw-bold">@item.NgayDat.ToString("dd/MM/yyyy")</div>
                            <div class="text-primary small fw-bold">@item.GioBatDau.ToString(@"hh\:mm") - @item.GioKetThuc.ToString(@"hh\:mm")</div>
                        </td>
                        <td>
                            <div class="fw-bold text-success">@item.TongTien.ToString("N0")đ</div>
                            <div class="text-muted smaller">Cọc: @item.TienCoc.ToString("N0")đ</div>
                        </td>
                        <td>
                            @{
                                var badgeClass = item.TrangThai == "Da hoan thanh" ? "bg-success" : 
                                               (item.TrangThai == "Da huy" ? "bg-danger" : 
                                               (item.TrangThai == "Da xac nhan" ? "bg-primary" : "bg-warning text-dark"));
                            }
                            <span class="badge @badgeClass rounded-pill px-3 py-2">@item.TrangThai</span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-1">
                                @if (item.TrangThai == "Cho xac nhan")
                                {
                                    <form asp-action="XacNhan" asp-route-id="@item.MaDatSan" method="post">
                                        <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3 fw-bold">Duyệt</button>
                                    </form>
                                }
                                @if (item.TrangThai != "Da hoan thanh" && item.TrangThai != "Da huy")
                                {
                                    <a asp-controller="HoaDon" asp-action="Create" asp-route-maDatSan="@item.MaDatSan" class="btn btn-sm btn-success rounded-pill px-3 fw-bold">
                                        <i class="fas fa-money-bill-wave me-1"></i> Thanh toán
                                    </a>
                                }
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.MaDatSan" class="btn btn-sm btn-white border"><i class="fas fa-edit text-primary"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.MaDatSan" class="btn btn-sm btn-white border"><i class="fas fa-eye"></i></a>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">Không có dữ liệu đơn đặt sân.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
