@model QUANLYSANBONG.Models.BlogPost
@{
    ViewData["Title"] = "Xóa bài viết";
    Layout = "_AdminLayout";
}

<div class="mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none small"><i class="fas fa-arrow-left me-1"></i> Quay lại danh sách</a>
    <h3 class="fw-bold mt-2 text-danger">Xác nhận xóa bài viết</h3>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="alert alert-warning border-0 shadow-xs mb-4">
            <i class="fas fa-exclamation-triangle me-2"></i> Bạn có chắc chắn muốn xóa bài viết này không? Hành động này không thể hoàn tác.
        </div>

        <div class="row align-items-center">
            <div class="col-md-4">
                <img src="@(string.IsNullOrEmpty(Model.AnhDaiDien) ? "/images/default-blog.jpg" : Model.AnhDaiDien)" class="img-fluid rounded-4 shadow-sm w-100" style="max-height: 250px; object-fit: cover;">
            </div>
            <div class="col-md-8">
                <h4 class="fw-bold">@Model.TieuDe</h4>
                <div class="text-muted mb-3">
                    <span class="badge bg-info-subtle text-info px-3">@Model.Category?.TenDanhMuc</span>
                    <span class="ms-3 small"><i class="far fa-calendar-alt me-1"></i> @Model.NgayDang.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <p class="text-dark">@Model.MoTaNgan</p>

                <form asp-action="Delete" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger px-5 py-2 shadow-sm rounded-pill fw-bold">XÓA VĨNH VIỄN</button>
                    <a asp-action="Index" class="btn btn-light px-5 py-2 ms-2 rounded-pill border">Hủy bỏ</a>
                </form>
            </div>
        </div>
    </div>
</div>
