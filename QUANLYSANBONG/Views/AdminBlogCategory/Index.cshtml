@model IEnumerable<QUANLYSANBONG.Models.BlogCategory>
@{
    ViewData["Title"] = "Quản lý chuyên mục Blog";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Chuyên mục Blog</h3>
    <a asp-action="Create" class="btn btn-primary px-4 shadow-sm">
        <i class="fas fa-plus me-2"></i>Thêm danh mục mới
    </a>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Tên danh mục</th>
                            <th>Slug</th>
                            <th>Mô tả</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.TenDanhMuc</td>
                                <td class="text-muted small">@item.Slug</td>
                                <td class="text-muted text-truncate" style="max-width: 300px;">@item.MoTa</td>
                                <td>
                                    @if (item.TrangThai)
                                    {
                                        <span class="badge bg-success-subtle text-success">Đang hiện</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">Đang ẩn</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-xs">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-white btn-sm border" title="Sửa"><i class="fas fa-edit text-primary"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-white btn-sm border" title="Xóa"><i class="fas fa-trash text-danger"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
